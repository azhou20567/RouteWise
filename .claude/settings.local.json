{
  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "PowerShell(Get-Process | Where-Object { $_.Name -match \"git|node|code|idea|cursor\" } | Select-Object Id, Name, CPU | Sort-Object Name)",
      "Bash(tasklist)",
      "Bash(taskkill /PID 21852 /F)",
      "Bash(taskkill /PID 21156 /F)",
      "Bash(cmd /c \"taskkill /PID 21852 /F\")",
      "Bash(cmd /c \"taskkill /PID 21156 /F\")",
      "Bash(git rm *)",
      "Bash(git add *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git filter-repo *)",
      "Bash(python -m git_filter_repo --version)",
      "Bash(pip install *)",
      "Bash(git remote *)"
    ]
  }
}
